# Configuration de la base de données
DB_HOST=localhost
DB_NAME=kara_db
DB_USER=kara_user
DB_PASS=votre_mot_de_passe_secure
DB_CHARSET=utf8mb4

# Configuration de l'application
APP_NAME="Kara Project - Gestion Académique"
APP_URL=https://votre-domaine.com
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=Africa/Abidjan

# Paramètres de session
SESSION_LIFETIME=120
SESSION_SECURE=true

# Upload
UPLOAD_MAX_FILESIZE=20M
POST_MAX_SIZE=25M

# Email (optionnel, pour les notifications)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=votre-email@gmail.com
MAIL_PASSWORD=votre-mot-de-passe
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@kara-project.com
MAIL_FROM_NAME="Kara Project"